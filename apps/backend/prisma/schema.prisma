generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  password               String
  name                   String?
  role                   Role                    @default(FOUNDER)
  organizationId         String?
  googleId               String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  actionFeedbacks        ActionFeedback[]
  actionItems            ActionItem[]
  aiUsage                AiUsage[]
  auditLogs              AuditLog[]
  chatThreads            ChatThread[]
  integrationConnections IntegrationConnection[]
  notifications          Notification[]
  rawImports             RawImport[]
  simulationLogs         SimulationLog[]
  startupProfile         StartupProfile?
  organization           Organization?           @relation(fields: [organizationId], references: [id])
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  industry               String?
  country                String                  @default("IN")
  currency               String                  @default("INR")
  fiscalYearStartMonth   Int                     @default(4)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  actionItems            ActionItem[]
  AiUsage                AiUsage[]
  bankAccounts           BankAccount[]
  budgets                Budget[]
  cfoDecisionEvents      CfoDecisionEvent[]
  cfoStateSnapshots      CfoStateSnapshot[]
  chatThreads            ChatThread[]
  complianceItems        ComplianceItem[]
  customers              Customer[]
  financialMetrics       FinancialMetrics[]
  financialSnapshots     FinancialSnapshot[]
  fundingRounds          FundingRound[]
  integrationConnections IntegrationConnection[]
  invoices               Invoice[]
  metricSnapshots        MetricSnapshot[]
  rawImports             RawImport[]
  recurringExpenses      RecurringExpense[]
  scenarios              Scenario[]
  simulationLogs         SimulationLog[]
  startupProfiles        StartupProfile?
  users                  User[]
  vendors                Vendor[]
  decisionFeedbacks      DecisionFeedback[]
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model BankAccount {
  id             String        @id @default(uuid())
  name           String
  accountNumber  String?
  bankName       String
  balance        Decimal       @default(0) @db.Decimal(15, 2)
  currency       String        @default("INR")
  organizationId String
  provider       String        @default("manual")
  externalId     String?
  lastSyncedAt   DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id])
  transactions   Transaction[]

  @@unique([organizationId, provider, externalId])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

model Transaction {
  id            String          @id @default(uuid())
  amount        Decimal         @db.Decimal(15, 2)
  type          TransactionType
  category      String
  description   String?
  date          DateTime
  bankAccountId String
  invoiceId     String?
  metadata      Json?
  source        String?
  externalId    String?
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  invoice       Invoice?        @relation(fields: [invoiceId], references: [id])

  @@unique([bankAccountId, externalId])
  @@index([bankAccountId, date])
  @@index([bankAccountId, type, date])
  @@index([date])
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String
  amount         Decimal       @db.Decimal(15, 2)
  tax            Decimal       @default(0) @db.Decimal(15, 2)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  organizationId String
  customerId     String?
  vendorId       String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer?     @relation(fields: [customerId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
  vendor         Vendor?       @relation(fields: [vendorId], references: [id])
  transactions   Transaction[]

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, deletedAt])
}

model Customer {
  id             String       @id @default(uuid())
  name           String
  email          String?
  gstin          String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]

  @@index([organizationId])
}

model Vendor {
  id             String       @id @default(uuid())
  name           String
  email          String?
  gstin          String?
  organizationId String
  createdAt      DateTime     @default(now())
  invoices       Invoice[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model FinancialMetrics {
  id                 String       @id @default(uuid())
  organizationId     String
  documentType       String
  period             String?
  currency           String       @default("INR")
  sourceFile         String
  confidence         String
  totalAssets        Decimal?     @db.Decimal(20, 2)
  totalLiabilities   Decimal?     @db.Decimal(20, 2)
  totalEquity        Decimal?     @db.Decimal(20, 2)
  currentAssets      Decimal?     @db.Decimal(20, 2)
  currentLiabilities Decimal?     @db.Decimal(20, 2)
  currentRatio       Decimal?     @db.Decimal(10, 4)
  debtToEquity       Decimal?     @db.Decimal(10, 4)
  revenue            Decimal?     @db.Decimal(20, 2)
  totalExpenses      Decimal?     @db.Decimal(20, 2)
  netProfit          Decimal?     @db.Decimal(20, 2)
  grossProfit        Decimal?     @db.Decimal(20, 2)
  ebitda             Decimal?     @db.Decimal(20, 2)
  profitMargin       Decimal?     @db.Decimal(10, 4)
  operatingCashFlow  Decimal?     @db.Decimal(20, 2)
  investingCashFlow  Decimal?     @db.Decimal(20, 2)
  financingCashFlow  Decimal?     @db.Decimal(20, 2)
  netCashFlow        Decimal?     @db.Decimal(20, 2)
  monthlyBurn        Decimal?     @db.Decimal(20, 2)
  cashRunway         Int?
  openingBalance     Decimal?     @db.Decimal(20, 2)
  closingBalance     Decimal?     @db.Decimal(20, 2)
  totalCredits       Decimal?     @db.Decimal(20, 2)
  totalDebits        Decimal?     @db.Decimal(20, 2)
  gstLiability       Decimal?     @db.Decimal(20, 2)
  inputTaxCredit     Decimal?     @db.Decimal(20, 2)
  netGstPayable      Decimal?     @db.Decimal(20, 2)
  totalInvoiceValue  Decimal?     @db.Decimal(20, 2)
  pendingReceivables Decimal?     @db.Decimal(20, 2)
  extractedFields    String[]
  warnings           String[]
  uploadedAt         DateTime     @default(now())
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, documentType])
  @@index([uploadedAt])
}

model AiUsage {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  endpoint       String
  model          String
  inputTokens    Int
  outputTokens   Int
  totalTokens    Int
  cost           Float
  latencyMs      Int
  cached         Boolean      @default(false)
  success        Boolean      @default(true)
  errorMessage   String?
  timestamp      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, timestamp])
  @@index([timestamp])
  @@index([endpoint])
}

model ComplianceItem {
  id             String             @id @default(uuid())
  organizationId String
  type           ComplianceType
  title          String
  description    String?
  dueDate        DateTime
  severity       ComplianceSeverity @default(MEDIUM)
  status         ComplianceStatus   @default(PENDING)
  amount         Decimal?           @db.Decimal(20, 2)
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([dueDate])
  @@index([status])
}

model Scenario {
  id                 String       @id @default(uuid())
  name               String
  organizationId     String
  headcount          Int          @default(0)
  monthlySalary      Decimal      @default(0) @db.Decimal(20, 2)
  saasSpend          Decimal      @default(0) @db.Decimal(20, 2)
  marketingSpend     Decimal      @default(0) @db.Decimal(20, 2)
  monthlyRevenue     Decimal      @default(0) @db.Decimal(20, 2)
  currentCash        Decimal      @default(0) @db.Decimal(20, 2)
  projectedBurn      Decimal      @default(0) @db.Decimal(20, 2)
  projectedRunway    Float        @default(0)
  monthlyProjections Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ActionItem {
  id                     String             @id @default(uuid())
  title                  String
  description            String?
  organizationId         String
  assignee               Assignee           @default(FOUNDER)
  status                 ActionStatus       @default(OPEN)
  expectedImpact         Decimal            @default(0) @db.Decimal(20, 2)
  actualImpact           Decimal?           @db.Decimal(20, 2)
  dueDate                DateTime?
  completedAt            DateTime?
  sourceInsight          String?
  sourceMetric           String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  actionType             String?
  appliedAt              DateTime?
  appliedBy              String?
  approvalStatus         ApprovalStatus     @default(NOT_APPLICABLE)
  claimedAt              DateTime?
  completionNotes        String?
  escalationLevel        Int                @default(0)
  executionMode          ExecutionMode      @default(SUGGESTED)
  executionPayload       Json?
  hasBeenNotified        Boolean            @default(false)
  isEscalated            Boolean            @default(false)
  isExecutable           Boolean            @default(false)
  isUnderReview          Boolean            @default(false)
  lastVerifiedAt         DateTime?
  overrideReason         String?
  priority               ActionPriority     @default(MEDIUM)
  seenInShadowMode       Boolean            @default(false)
  userId                 String?
  verificationConfidence Int                @default(0)
  verificationNotes      String?
  verificationReason     String?
  verificationStatus     VerificationStatus @default(UNVERIFIED)
  verificationWindow     Int                @default(7)
  feedback               ActionFeedback[]
  organization           Organization       @relation(fields: [organizationId], references: [id])
  user                   User?              @relation(fields: [userId], references: [id])
  autoPilotLogs          AutoPilotLog[]
  executionLogs          ExecutionLog[]

  @@index([organizationId, status])
  @@index([organizationId, assignee])
  @@index([dueDate])
}

model ActionFeedback {
  id        String       @id @default(uuid())
  actionId  String
  userId    String
  type      FeedbackType @default(DISAGREE)
  message   String
  createdAt DateTime     @default(now())
  action    ActionItem   @relation(fields: [actionId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@index([actionId])
  @@index([userId])
}

model ExecutionLog {
  id              String                 @id @default(uuid())
  actionId        String
  executedAt      DateTime               @default(now())
  impactExpected  Json?
  impactActual    Json?
  status          String
  decisionQuality DecisionQuality?
  classification  OutcomeClassification?
  processScore    Float?
  accuracyScore   Float?
  impactDelta     Float?
  failureReason   String?
  contextSnapshot Json?
  profileId       String?
  metadata        Json?
  explanation     Json?                  // v2.2 Structured reasoning
  action          ActionItem             @relation(fields: [actionId], references: [id])
  profile         StartupProfile?        @relation(fields: [profileId], references: [id])

  @@index([actionId])
  @@index([profileId])
}

model CfoCategoryPerformance {
  id              String   @id @default(uuid())
  organizationId  String
  category        String
  recentAccuracy  Json?
  failureStreak   Int      @default(0)
  confidenceScore Float    @default(100)
  isSuppressed    Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  @@unique([organizationId, category])
  @@index([organizationId])
}

model AutoPilotLog {
  id          String             @id @default(uuid())
  profileId   String
  actionId    String
  status      AutoPilotLogStatus @default(EXECUTED)
  executedAt  DateTime           @default(now())
  executeAt   DateTime?
  reason      String
  confidence  Float
  riskLevel   AutoPilotRisk
  isSimulated Boolean            @default(false)
  isRollback  Boolean            @default(false)
  impactBurn  Float?
  metadata    Json?
  action      ActionItem         @relation(fields: [actionId], references: [id])
  profile     StartupProfile     @relation(fields: [profileId], references: [id])

  @@index([profileId])
  @@index([actionId])
}

model StartupProfileVersion {
  id        String         @id @default(uuid())
  profileId String
  changes   Json
  source    String         @default("AUTO_EXECUTION")
  userId    String?
  createdAt DateTime       @default(now())
  profile   StartupProfile @relation(fields: [profileId], references: [id])

  @@index([profileId])
}

model StartupProfile {
  id                      String                   @id @default(uuid())
  userId                  String                   @unique
  organizationId          String                   @unique
  companyName             String
  stage                   StartupStage
  monthlyRevenue          Decimal                  @db.Decimal(20, 2)
  monthlyExpenses         Decimal                  @db.Decimal(20, 2)
  cashInBank              Decimal                  @db.Decimal(20, 2)
  teamSize                Int
  country                 String                   @default("IN")
  industry                String
  primaryGoal             PrimaryGoal
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastCriticalEmailSentAt DateTime?
  lastAlertGeneratedAt    DateTime?
  ignoredAlertsCount      Int                      @default(0)
  daysSinceLastAction     Int                      @default(0)
  autoPilotDelayMinutes   Int                      @default(30)
  autoPilotEnabledAt      DateTime?
  autoPilotFailureStreak  Int                      @default(0)
  autoPilotMode           AutoPilotMode            @default(OFF)
  cautionMultiplier       Float                    @default(1.0)
  cfoAccuracyScore        Float                    @default(85)
  complianceScore         Int                      @default(100)
  envUncertaintyScore     Float                    @default(0)
  growthMode              Boolean                  @default(false)
  hiringFreeze            Boolean                  @default(false)
  isTrustZoneDowngraded   Boolean                  @default(false)
  lastAccuracyUpdate      DateTime                 @default(now())
  lastAutoPilotFailureAt  DateTime?
  lastAutoPilotScanAt     DateTime?
  lastScoreUpdate         DateTime                 @default(now())
  marketingMultiplier     Float                    @default(1.0)
  maxAutoBurnImpact       Float                    @default(5.0)
  rollbackRate            Float                    @default(0)
  rolledBackAutoActions   Int                      @default(0)
  salesMultiplier         Float                    @default(1.0)
  shadowModeEnabled       Boolean                  @default(true)
  targetBurn              Float?
  totalAutoActions        Int                      @default(0)
  totalEvaluatedActions   Int                      @default(0)
  
  // v2.1 Hybrid Decision Engine Upgrades
  lastDashboardMode       String?                  @default("STABLE")
  modeStagingCount        Int                      @default(0)
  lastSnapshotAt          DateTime?
  highestCashBuffer       Float?                   @default(0)
  rollbackRecoveryCount   Int                      @default(0)
  
  decisionSensitivity     SensitivityLevel         @default(BALANCED)
  notificationPreference  AlertTier                @default(IMPORTANT)
  
  autoPilotLogs           AutoPilotLog[]
  cfoDecisions            CfoDecision[]
  logs                    ExecutionLog[]
  organization            Organization             @relation(fields: [organizationId], references: [id])
  user                    User                     @relation(fields: [userId], references: [id])
  snapshots               StartupProfileSnapshot[]
  versions                StartupProfileVersion[]

  @@index([organizationId])
}

model StartupProfileSnapshot {
  id               String         @id @default(uuid())
  startupProfileId String
  stage            StartupStage
  monthlyRevenue   Decimal        @db.Decimal(20, 2)
  monthlyExpenses  Decimal        @db.Decimal(20, 2)
  cashInBank       Decimal        @db.Decimal(20, 2)
  teamSize         Int
  primaryGoal      PrimaryGoal
  snapshotAt       DateTime       @default(now())
  projectedRunway  Float          @default(0)
  startupProfile   StartupProfile @relation(fields: [startupProfileId], references: [id])

  @@index([startupProfileId])
  @@index([snapshotAt])
}

model CfoDecision {
  id                 String         @id @default(uuid())
  startupProfileId   String
  decisionDomain     DecisionDomain
  decisionType       String
  severity           String
  confidence         Float
  facts              Json
  recommendedActions Json
  status             DecisionStatus @default(OPEN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  aiExplanation      AiExplanation?
  startupProfile     StartupProfile @relation(fields: [startupProfileId], references: [id])

  @@index([startupProfileId, status])
  @@index([createdAt])
  @@index([decisionDomain])
}

model AiExplanation {
  id              String      @id @default(uuid())
  cfoDecisionId   String      @unique
  modelUsed       String
  explanationText String
  tone            String
  latencyMs       Int
  createdAt       DateTime    @default(now())
  cfoDecision     CfoDecision @relation(fields: [cfoDecisionId], references: [id])
}

model FinancialSnapshot {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  snapshotDate   DateTime     @default(now())
  revenue        Decimal      @db.Decimal(20, 2)
  expenses       Decimal      @db.Decimal(20, 2)
  cashBalance    Decimal      @db.Decimal(20, 2)
  burn           Decimal      @db.Decimal(20, 2)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, snapshotDate])
  @@index([userId])
}

model WeeklyBrief {
  id                String   @id @default(uuid())
  userId            String
  organizationId    String
  weekStart         DateTime
  summaryText       String
  topRisk           String
  topRecommendation String
  metricsJson       Json
  createdAt         DateTime @default(now())

  @@index([userId, weekStart])
  @@index([organizationId])
}

model Alert {
  id               String       @id @default(uuid())
  userId           String
  organizationId   String
  decisionId       String?
  alertType        String
  severity         String
  message          String
  metadata         Json?
  acknowledged     Boolean      @default(false)
  channel          AlertChannel @default(IN_APP)
  status           AlertStatus  @default(SENT)
  createdAt        DateTime     @default(now())
  firstDetectedAt  DateTime     @default(now())
  lastSentAt       DateTime     @default(now())
  previousSeverity String?

  @@index([userId, alertType, createdAt])
  @@index([decisionId])
  @@index([organizationId])
}

model Budget {
  id             String       @id @default(uuid())
  organizationId String
  category       String
  period         String
  plannedAmount  Decimal      @db.Decimal(20, 2)
  actualAmount   Decimal      @default(0) @db.Decimal(20, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, category, period])
  @@index([organizationId, period])
}

model SimulationLog {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  inputSnapshot  Json
  impactSummary  Json
  riskLevel      String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
}

model FundingRound {
  id             String             @id @default(uuid())
  organizationId String
  roundType      FundingRoundType
  targetAmount   Decimal            @db.Decimal(20, 2)
  raisedAmount   Decimal            @default(0) @db.Decimal(20, 2)
  valuation      Decimal?           @db.Decimal(20, 2)
  dilution       Decimal?           @db.Decimal(5, 4)
  status         FundingRoundStatus @default(PLANNING)
  leadInvestor   String?
  closedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
}

model MetricSnapshot {
  id             String       @id @default(uuid())
  organizationId String
  metricKey      String
  value          Decimal      @db.Decimal(20, 4)
  unit           String?
  period         String
  source         String?
  recordedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, metricKey, period])
  @@index([organizationId, metricKey])
  @@index([organizationId, period])
}

model RecurringExpense {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  vendor         String?
  amount         Decimal          @db.Decimal(20, 2)
  frequency      ExpenseFrequency @default(MONTHLY)
  category       String
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean          @default(true)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
  @@index([organizationId, category])
}

model ChatThread {
  id             String        @id @default(uuid())
  organizationId String
  userId         String
  title          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([organizationId, userId])
  @@index([updatedAt])
}

model ChatMessage {
  id           String      @id @default(uuid())
  threadId     String
  role         MessageRole
  content      String
  inputTokens  Int?
  outputTokens Int?
  model        String?
  latencyMs    Int?
  createdAt    DateTime    @default(now())
  thread       ChatThread  @relation(fields: [threadId], references: [id])

  @@index([threadId, createdAt])
}

model IntegrationConnection {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  provider       String
  status         String
  syncStatus     SyncStatus   @default(IDLE)
  lastError      String?
  accessMetadata Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  syncLogs       SyncLog[]

  @@index([organizationId, provider])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String
  eventId     String    @unique
  eventType   String
  payload     Json
  processed   Boolean   @default(false)
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([provider, processed])
}

model SyncLog {
  id            String                @id @default(uuid())
  connectionId  String
  provider      String
  syncType      String
  status        String
  recordsSynced Int                   @default(0)
  errorDetails  String?
  durationMs    Int?
  createdAt     DateTime              @default(now())
  connection    IntegrationConnection @relation(fields: [connectionId], references: [id])

  @@index([connectionId, createdAt])
}

model RawImport {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  provider       String
  sourceType     String
  rawPayload     Json
  status         String
  importedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model CfoStateSnapshot {
  id                String       @id @default(uuid())
  organizationId    String
  companyStatus     String
  runwayMonths      Float
  daysLeft          Int?
  cashInBank        Float
  monthlyRevenue    Float
  monthlyExpenses   Float
  netBurn           Float
  burnTrend         String
  revenueTrend      String
  tone              String
  transactionCount  Int          @default(0)
  riskScore         Float?       @default(0)
  dataQuality       String
  totalReceivables  Float        @default(0)
  runwayChangeDays  Int?
  burnChangePercent Float?
  cashChangeAmount  Float?
  riskChanged       Boolean      @default(false)
  statusChanged     Boolean      @default(false)
  fullState         Json
  explanation       Json?        // Structured reasoning for mode/state
  generatedAt       DateTime     @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, generatedAt])
  @@index([organizationId])
}

model CfoDecisionEvent {
  id                String       @id @default(uuid())
  organizationId    String
  decisionId        String
  decisionStatement String
  optionChosen      String?
  firstShownAt      DateTime     @default(now())
  lastShownAt       DateTime     @default(now())
  clickedAt         DateTime?
  actedAt           DateTime?
  resolvedAt        DateTime?
  acknowledged      Boolean      @default(false)
  acted             Boolean      @default(false)
  resolved          Boolean      @default(false)
  outcome           String?
  runwayAtShown     Float?
  runwayAtResolved  Float?
  runwayDelta       Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, decisionId])
  @@index([organizationId, resolved])
  @@index([organizationId, createdAt])
}

