# ============================================================
# FounderCFO Backend — Environment Variables v2
# ============================================================
# Copy to .env and fill in all values marked REQUIRED.
# Never commit .env to git.

# ─── Database ────────────────────────────────────────────────
# REQUIRED
DATABASE_URL="postgresql://admin:YOUR_PASSWORD@localhost:5432/foundercfo?schema=public"

# ─── Redis ───────────────────────────────────────────────────
# Used for: rate limiting, session caching, AI response caching
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────
# REQUIRED — Generate: openssl rand -base64 64
JWT_SECRET="GENERATE_A_STRONG_64_CHARACTER_SECRET_HERE"
JWT_EXPIRATION="15m"

# REQUIRED — Short-lived access tokens + long-lived refresh tokens
# Generate: openssl rand -base64 64
REFRESH_TOKEN_SECRET="GENERATE_A_DIFFERENT_64_CHARACTER_SECRET_HERE"
REFRESH_TOKEN_EXPIRATION="30d"

# ─── Google AI (Gemini) ───────────────────────────────────────
# REQUIRED — https://makersuite.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Model selection per task (cost optimization)
GEMINI_FLASH_MODEL="gemini-1.5-flash"   # Fast, cheap — decisions & categorization
GEMINI_PRO_MODEL="gemini-1.5-pro"       # Powerful — explanations & reports

# ─── AI Cost Controls ─────────────────────────────────────────
# Per-org monthly AI spend cap (USD). Requests blocked above this.
AI_MAX_COST_PER_ORG_USD=10.00

# Per-hour per-org rate limit (number of AI requests)
AI_RATE_LIMIT_PER_ORG_PER_HOUR=50

# ─── Google OAuth ─────────────────────────────────────────────
# REQUIRED — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"

# ─── Application ─────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
APP_VERSION="0.0.2"
FRONTEND_URL="http://localhost:3000"

# ─── File Uploads ─────────────────────────────────────────────
# Financial document upload limits
MAX_FILE_SIZE_MB=10
# Comma-separated allowed MIME types
ALLOWED_FILE_TYPES="application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv"

# Storage: 'local' | 's3'
FILE_STORAGE_BACKEND="local"
# If s3:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION="ap-south-1"

# ─── Encryption ───────────────────────────────────────────────
# REQUIRED — For encrypting sensitive fields at rest (GSTIN, account numbers)
# Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY="GENERATE_A_32_BYTE_HEX_KEY_HERE"

# ─── Error Monitoring ─────────────────────────────────────────
# https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=""

# ─── Notifications ────────────────────────────────────────────
# WhatsApp alerts via Twilio (optional — for compliance deadline alerts)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Email via Resend (optional — for invoice notifications and CFO alerts)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@foundercfo.in"

# ─── Compliance Calendar ──────────────────────────────────────
# Cron schedule for auto-generating compliance deadlines (IST)
# Default: every day at 8am IST
COMPLIANCE_CRON="0 8 * * *"

# ─── Production Overrides ────────────────────────────────────
# Uncomment and fill when deploying to production:
# NODE_ENV="production"
# DATABASE_URL="postgresql://user:pass@prod-db:5432/foundercfo"
# ALLOWED_ORIGINS="https://app.foundercfo.in"
# GOOGLE_CALLBACK_URL="https://api.foundercfo.in/auth/google/callback"
# FRONTEND_URL="https://app.foundercfo.in"
# JWT_EXPIRATION="15m"
# FILE_STORAGE_BACKEND="s3"
