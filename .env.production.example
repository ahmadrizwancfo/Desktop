# FounderCFO Production Environment Variables
# Copy this file to .env and fill in all values

# ============================================
# Database
# ============================================
DB_PASSWORD=your-secure-database-password

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your-64-character-jwt-secret-here

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback

# ============================================
# URLs
# ============================================
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# AI Services
# ============================================
# Google Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# Error Monitoring (Sentry)
# ============================================
# Get from https://sentry.io -> Project Settings -> Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id
FRONTEND_SENTRY_DSN=https://your-frontend-key@sentry.io/your-project-id

# ============================================
# Environment
# ============================================
NODE_ENV=production
APP_VERSION=1.0.0

# ============================================
# Optional: Deployment
# ============================================
# SERVER_HOST=your-server-ip
# SERVER_USER=deploy
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
